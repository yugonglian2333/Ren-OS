---
// 主题切换：跟随系统默认 + localStorage 记忆
// 通过 inline 脚本在首屏避免 FOUC
---

<button
  id="theme-toggle"
  type="button"
  aria-label="切换深浅主题"
  class="relative inline-flex h-9 w-9 items-center justify-center rounded-[var(--radius-button)] border transition-colors"
  style="border-color: var(--color-border);"
>
  <svg class="h-4 w-4 block dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="4" />
    <path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41" />
  </svg>
  <svg class="h-4 w-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
  </svg>
</button>

<script is:inline>
  // 首屏：在 DOM 渲染前同步应用主题，避免闪烁
  (function () {
    try {
      var stored = localStorage.getItem("renos-theme");
      var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
      var theme = stored || (prefersDark ? "dark" : "light");
      if (theme === "dark") document.documentElement.classList.add("dark");
    } catch (e) {}
  })();

  // 切换逻辑
  document.addEventListener("DOMContentLoaded", function () {
    var btn = document.getElementById("theme-toggle");
    if (!btn) return;
    btn.addEventListener("click", function () {
      var isDark = document.documentElement.classList.toggle("dark");
      try {
        localStorage.setItem("renos-theme", isDark ? "dark" : "light");
      } catch (e) {}
    });
  });
</script>