---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  /** 文章页专用：类型改为 article */
  type?: "website" | "article";
  /** 文章页专用：发布时间 */
  publishedTime?: Date;
  /** 文章页专用：分类 */
  section?: string;
}

const {
  title = "RenOS — AI Dev",
  description = "RenOS：擅长把 idea 快速落地并持续迭代的独立开发者，正在打造一路记 WayLog 与 Saymore。",
  image = "/og-default.jpg",
  type = "website",
  publishedTime,
  section,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.url).href;

// JSON-LD 结构化数据
const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "RenOS",
  url: "https://www.renos.top",
  jobTitle: "AI Builder",
  description: "独立开发者。擅长把 idea 快速落地并持续迭代，正在打造一路记 WayLog 与 Saymore。",
  sameAs: [
    "https://github.com/yugonglian2333",
    "https://x.com/yugonglian12",
  ],
};

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "RenOS",
  url: "https://www.renos.top",
  description: "独立开发者 RenOS 的产品、文章与长期探索",
  author: { "@type": "Person", name: "RenOS" },
  publisher: { "@type": "Person", name: "RenOS" },
};

const articleSchema =
  type === "article" && publishedTime
    ? {
        "@context": "https://schema.org",
        "@type": "Article",
        headline: title,
        description: description,
        image: socialImage,
        datePublished: publishedTime.toISOString(),
        dateModified: publishedTime.toISOString(),
        author: { "@type": "Person", name: "RenOS", url: "https://www.renos.top" },
        publisher: { "@type": "Person", name: "RenOS", url: "https://www.renos.top" },
        mainEntityOfPage: { "@type": "WebPage", "@id": canonicalURL.href },
        ...(section ? { articleSection: section } : {}),
      }
    : null;
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<meta name="generator" content={Astro.generator} />
<meta name="robots" content="index, follow" />
<meta name="baidu-site-verification" content="codeva-856ny6Wp8K" />

<link rel="icon" type="image/png" href="/favicon.png" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link rel="canonical" href={canonicalURL} />

<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content="RenOS" />
<meta name="keywords" content="RenOS, 独立开发者, AI builder, Agent, WayLog, 一路记, Saymore, 语音输入, ASR, LLM, 个人博客" />

<!-- Open Graph -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={socialImage} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:image:alt" content={title} />
<meta property="og:site_name" content="RenOS" />
<meta property="og:locale" content="zh_CN" />

{type === "article" && publishedTime && (
  <>
    <meta property="article:published_time" content={publishedTime.toISOString()} />
    <meta property="article:author" content="RenOS" />
    {section && <meta property="article:section" content={section} />}
  </>
)}

<!-- Twitter / X -->
<meta property="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content={canonicalURL} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
<meta property="twitter:image" content={socialImage} />
<meta name="twitter:site" content="@yugonglian12" />
<meta name="twitter:creator" content="@yugonglian12" />

<!-- JSON-LD 结构化数据 -->
<script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
<script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
{articleSchema && (
  <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
)}

<!-- 字体（自托管，零外部请求） -->
<style>
  @import "@fontsource/inter/400.css";
  @import "@fontsource/inter/500.css";
  @import "@fontsource/inter/600.css";
  @import "@fontsource/inter/700.css";
  @import "@fontsource/noto-sans-sc/400.css";
  @import "@fontsource/noto-sans-sc/500.css";
  @import "@fontsource/noto-sans-sc/700.css";
  @import "@fontsource/jetbrains-mono/400.css";
  @import "@fontsource/jetbrains-mono/500.css";
  @import "@fontsource/source-serif-4/400.css";
  @import "@fontsource/source-serif-4/500.css";
  @import "@fontsource/source-serif-4/600.css";
  @import "@fontsource/source-serif-4/400-italic.css";
</style>
