---
interface Props {
  eyebrow?: string;
  title: string;
  href?: string;
}
const { eyebrow, title, href } = Astro.props;
---

<div class="mb-4 flex items-baseline justify-between gap-4">
  <div class="flex items-baseline gap-2">
    {eyebrow && (
      <span class="font-mono text-xs uppercase tracking-wider" style="color: var(--color-text-subtle);">
        {eyebrow}
      </span>
    )}
    <h2 class="text-xl font-semibold tracking-tight">{title}</h2>
  </div>
  {href && (
    <a href={href} class="shrink-0 text-sm link-quiet">查看全部 →</a>
  )}
</div>