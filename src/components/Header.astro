---
import ThemeToggle from "./ThemeToggle.astro";
import { navItems, isActive } from "./nav";

const path = Astro.url.pathname;
---

<header class="sticky top-0 z-50 backdrop-blur-md" style="background: color-mix(in oklab, var(--color-bg) 80%, transparent); border-bottom: 1px solid var(--color-border);">
  <div class="section-wide flex h-14 items-center justify-between">
    <a href="/" class="group inline-flex items-center gap-2 text-[15px] font-semibold tracking-tight">
      <img src="/ren-avatar.jpg" alt="Ren" width="24" height="24" class="h-6 w-6 rounded-md object-cover" />
      <span class="transition-colors group-hover:text-[color:var(--color-accent)]">RenOS</span>
    </a>

    <nav class="hidden items-center gap-1 sm:flex" aria-label="主导航">
      {navItems.map((item) => (
        <a
          href={item.href}
          class:list={[
            "rounded-[var(--radius-button)] px-3 py-1.5 text-sm transition-colors",
            isActive(path, item.href)
              ? "text-[color:var(--color-text)] font-medium"
              : "text-[color:var(--color-text-muted)] hover:text-[color:var(--color-text)]",
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <div class="flex items-center gap-1.5">
      <button
        type="button"
        id="mobile-nav-toggle"
        class="mobile-nav-toggle inline-flex h-9 w-9 items-center justify-center rounded-[var(--radius-button)] border transition-colors sm:hidden"
        style="border-color: var(--color-border); color: var(--color-text-muted);"
        aria-label="打开导航菜单"
        aria-expanded="false"
        aria-controls="mobile-nav-panel"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" aria-hidden="true">
          <path d="M2.5 5h13M2.5 9h13M2.5 13h13" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
      </button>
      <ThemeToggle />
    </div>
  </div>
</header>

<style>
  .mobile-nav-toggle:hover {
    color: var(--color-text);
    border-color: color-mix(in oklab, var(--color-text) 25%, var(--color-border));
  }
</style>
