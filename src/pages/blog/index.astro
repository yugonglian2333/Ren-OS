---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";
import { BLOG_CATEGORIES } from "../../content/categories";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort((a, b) => {
  if (a.data.pinned !== b.data.pinned) return a.data.pinned ? -1 : 1;
  if (a.data.priority !== b.data.priority) return b.data.priority - a.data.priority;
  return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
});

const byCategory = (cat: string) => posts.filter((p) => p.data.category === cat);
---

<BaseLayout title="文章 — RenOS" description="一些代码之外的思考，一些思考之外的代码。">
  <section class="section">
    <p class="font-mono text-xs uppercase tracking-[0.15em]" style="color: var(--color-accent);" data-fade>文章</p>
    <div class="mt-4 border-l-4 pl-5" data-fade style="border-color: var(--color-accent);">
      <p class="font-serif text-base leading-relaxed sm:text-lg">
        一些代码之外的思考，一些思考之外的代码。
      </p>
    </div>

    <!-- 分类导航 tabs -->
    <div class="mt-10 flex flex-wrap gap-2" data-fade id="category-tabs">
      <a href="/blog" class="category-tab" data-cat="">全部（{posts.length}）</a>
      {BLOG_CATEGORIES.map((cat) => {
        const count = byCategory(cat).length;
        return (
          <a href={`/blog?category=${encodeURIComponent(cat)}`} class="category-tab" data-cat={cat} data-count={count}>{cat}（{count}）</a>
        );
      })}
    </div>

    <p id="empty-category" class="mt-10 hidden text-sm" style="color: var(--color-text-muted);" data-fade>
      这个分类还没有文章。
    </p>

    {posts.length === 0 ? (
      <div data-fade>
        <p class="mt-10 text-[15px]" style="color: var(--color-text-muted);">
          第一篇还在路上。骨架已搭好（项目介绍 / 学习笔记 / 面经 / 工具），随手往
          <code class="font-mono text-xs" style="color: var(--color-accent);">src/content/blog/</code>
          丢一个 mdx 就能上线。
        </p>
      </div>
    ) : (
      BLOG_CATEGORIES.map((cat) => {
        const list = byCategory(cat);
        if (list.length === 0) return null;
        return (
          <div class="mb-10 category-section" data-category={cat} data-fade>
            <h2 class="mb-2 mt-6 font-mono text-xs uppercase tracking-wider" style="color: var(--color-text-subtle);">
              {cat}
            </h2>
            <div>
              {list.map((post) => (
                <a
                  href={`/blog/${post.slug}`}
                  class="group flex items-baseline justify-between gap-4 py-3 transition-colors"
                  style="border-bottom: 1px solid var(--color-border);"
                >
                  <div class="min-w-0 flex-1">
                    <div class="flex items-baseline gap-2">
                      {post.data.pinned && (
                        <span class="shrink-0 font-mono text-[10px] uppercase tracking-wider" style="color: var(--color-accent);">
                          置顶
                        </span>
                      )}
                      <span class="shrink-0 text-[10px] font-mono uppercase tracking-wider" style="color: var(--color-accent);">
                        {post.data.category}
                      </span>
                      <span class="text-[15px] font-medium group-hover:text-[color:var(--color-accent)] transition-colors">
                        {post.data.title}
                      </span>
                    </div>
                    <p class="mt-0.5 text-sm" style="color: var(--color-text-muted);">{post.data.description}</p>
                  </div>
                  <time class="shrink-0 font-mono text-xs" style="color: var(--color-text-subtle);">
                    {post.data.pubDate.toLocaleDateString("zh-CN", { year: "numeric", month: "2-digit", day: "2-digit" })}
                  </time>
                </a>
              ))}
            </div>
          </div>
        );
      })
    )}
  </section>
</BaseLayout>

<script>
function applyCategoryFilter() {
    const params = new URLSearchParams(location.search);
    const active = params.get("category") || "";
    let activeCount = 0;

    // 切换 tab 高亮
    document.querySelectorAll("#category-tabs .category-tab").forEach((tab) => {
      if (!(tab instanceof HTMLElement)) return;
      const cat = tab.dataset.cat || "";
      tab.classList.toggle("category-tab-active", cat === active);
      if (cat === active) activeCount = Number(tab.dataset.count || 0);
    });

    // 切换文章分类显隐
    document.querySelectorAll(".category-section").forEach((sec) => {
      if (!(sec instanceof HTMLElement)) return;
      const cat = sec.dataset.category || "";
      if (!active || cat === active) {
        sec.style.display = "";
      } else {
        sec.style.display = "none";
      }
    });

    document.querySelector("#empty-category")?.classList.toggle("hidden", !active || activeCount > 0);
  }

  // 初始加载 + Astro 导航时都触发
  document.addEventListener("astro:page-load", applyCategoryFilter);
  document.addEventListener("DOMContentLoaded", applyCategoryFilter);
</script>

<style is:global>
  .category-tab {
    padding: 4px 12px;
    border-radius: 999px;
    font-size: 12px;
    font-family: var(--font-mono, ui-monospace, monospace);
    border: 0.5px solid var(--color-border);
    color: var(--color-text-muted);
    transition: all 0.2s ease;
    text-decoration: none;
  }
  .category-tab:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
  }
  .category-tab-active {
    background: var(--color-accent);
    color: #fff;
    border-color: var(--color-accent);
  }
  .category-tab-active:hover {
    opacity: 0.9;
  }
</style>
