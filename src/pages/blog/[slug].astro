---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getCollection, type CollectionEntry } from "astro:content";

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await post.render();
const { title, description, pubDate, category } = post.data;

const dateStr = pubDate.toLocaleDateString("zh-CN", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<BaseLayout
  title={`${title} — RenOS`}
  description={description}
  type="article"
  publishedTime={pubDate}
  section={category}
>
  <article class="section">
    <header data-fade>
      <div class="flex items-center gap-3 text-xs" style="color: var(--color-text-subtle);">
        <span class="font-mono uppercase tracking-wider" style="color: var(--color-accent);">{category}</span>
        <span>·</span>
        <time class="font-mono">{dateStr}</time>
      </div>
      <h1 class="mt-3 text-3xl font-bold leading-tight tracking-tight sm:text-4xl">{title}</h1>
      {description && (
        <p class="mt-3 text-[15px] leading-relaxed" style="color: var(--color-text-muted);">{description}</p>
      )}
    </header>

    <div class="prose-renos mt-10" data-fade>
      <Content />
    </div>

    <div class="mt-16 flex items-center justify-between border-t pt-6" style="border-color: var(--color-border);">
      <a href="/blog" class="link-quiet text-sm">← 回文章列表</a>
      <a href="/" class="link-quiet text-sm">回到首页</a>
    </div>
  </article>
</BaseLayout>

<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Source+Sans+3:ital,wght@0,300;0,400;0,600;0,700;1,400&family=Roboto+Mono:wght@400;500&display=swap"
/>

<style is:global>
  /* ============================================================
     Typora Vue 主题 —— 原封不动移植
     来源：vue.css（@kkHAIKE），保留全部原始色值与排版
     选择器 #write → .prose-renos 映射，其余完全照搬
     ============================================================ */

  .prose-renos {
    --font-sans-serif: 'Source Sans 3', 'Source Sans Pro', 'Noto Sans SC', sans-serif;
    --font-monospace: 'Roboto Mono', ui-monospace, monospace;

    font-family: var(--font-sans-serif);
    color: #34495e;
    -webkit-font-smoothing: antialiased;
    line-height: 1.6rem;
    letter-spacing: 0;
    font-size: 16px;
  }

  .prose-renos p {
    line-height: 1.6rem;
    word-spacing: .05rem;
    margin: 0.8em 0;
  }

  .prose-renos ol li {
    padding-left: 0.5rem;
  }

  .prose-renos a {
    color: #42b983;
    font-weight: 600;
    padding: 0 2px;
    text-decoration: none;
  }

  .prose-renos h1,
  .prose-renos h2,
  .prose-renos h3,
  .prose-renos h4,
  .prose-renos h5,
  .prose-renos h6 {
    position: relative;
    margin-top: 1rem;
    margin-bottom: 1rem;
    font-weight: bold;
    line-height: 1.4;
    cursor: text;
  }

  .prose-renos h1 tt,
  .prose-renos h1 code,
  .prose-renos h2 tt,
  .prose-renos h2 code,
  .prose-renos h3 tt,
  .prose-renos h3 code,
  .prose-renos h4 tt,
  .prose-renos h4 code,
  .prose-renos h5 tt,
  .prose-renos h5 code,
  .prose-renos h6 tt,
  .prose-renos h6 code {
    font-size: inherit !important;
  }

  .prose-renos h2 a,
  .prose-renos h3 a {
    color: #34495e;
  }

  .prose-renos h1 {
    padding-bottom: .4rem;
    font-size: 2.2rem;
    line-height: 1.3;
  }

  .prose-renos h2 {
    font-size: 1.75rem;
    line-height: 1.225;
    margin: 35px 0 15px;
    padding-bottom: 0.5em;
    border-bottom: 1px solid #ddd;
  }

  .prose-renos h3 {
    font-size: 1.4rem;
    line-height: 1.43;
    margin: 20px 0 7px;
  }

  .prose-renos h4 {
    font-size: 1.2rem;
  }

  .prose-renos h5 {
    font-size: 1rem;
  }

  .prose-renos h6 {
    font-size: 1rem;
    color: #777;
  }

  .prose-renos p,
  .prose-renos blockquote,
  .prose-renos ul,
  .prose-renos ol,
  .prose-renos dl,
  .prose-renos table {
    margin: 0.8em 0;
  }

  .prose-renos li > ol,
  .prose-renos li > ul {
    margin: 0 0;
  }

  .prose-renos hr {
    height: 2px;
    padding: 0;
    margin: 16px 0;
    background-color: #e7e7e7;
    border: 0 none;
    overflow: hidden;
    box-sizing: content-box;
  }

  .prose-renos ul,
  .prose-renos ol {
    padding-left: 30px;
  }

  .prose-renos blockquote {
    border-left: 4px solid #42b983;
    padding: 10px 15px;
    color: #777;
    background-color: rgba(66, 185, 131, .1);
  }

  .prose-renos table {
    padding: 0;
    word-break: initial;
  }

  .prose-renos table tr {
    border-top: 1px solid #dfe2e5;
    margin: 0;
    padding: 0;
  }

  .prose-renos table tr:nth-child(2n),
  .prose-renos thead {
    background-color: #fafafa;
  }

  .prose-renos table tr th {
    font-weight: bold;
    border: 1px solid #dfe2e5;
    border-bottom: 0;
    text-align: left;
    margin: 0;
    padding: 6px 13px;
  }

  .prose-renos table tr td {
    border: 1px solid #dfe2e5;
    text-align: left;
    margin: 0;
    padding: 6px 13px;
  }

  .prose-renos strong {
    padding: 0 1px;
  }

  .prose-renos em {
    padding: 0 5px 0 2px;
  }

  .prose-renos table thead th {
    background-color: #f2f2f2;
  }

  .prose-renos pre {
    border: 1px solid #F4F4F4;
    -webkit-font-smoothing: initial;
    margin: 0.8rem 0 !important;
    padding: 0.3rem 1rem !important;
    line-height: 1.43rem;
    background-color: #F8F8F8 !important;
    border-radius: 2px;
    font-family: var(--font-monospace);
    font-size: 0.85rem;
    word-wrap: normal;
    overflow-x: auto;
  }

  .prose-renos code,
  .prose-renos tt {
    padding: 2px 4px;
    border-radius: 2px;
    font-family: var(--font-monospace);
    font-size: 0.92rem;
    color: #e96900;
    background-color: #f8f8f8;
  }

  .prose-renos pre code {
    padding: 0;
    border-radius: 0;
    color: inherit;
    background-color: transparent;
    font-size: inherit;
  }

  .prose-renos tt {
    margin: 0 2px;
  }

  .prose-renos mark {
    background-color: #EBFFEB;
    border-radius: 2px;
    padding: 2px 4px;
    margin: 0 2px;
    color: #222;
    font-weight: 500;
  }

  .prose-renos del {
    padding: 1px 2px;
  }

  .prose-renos img {
    max-width: 100%;
  }
</style>
