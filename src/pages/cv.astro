---
import BaseLayout from "../layouts/BaseLayout.astro";
import SectionTitle from "../components/SectionTitle.astro";

// 经历时间线（占位，后续填真实经历）
const timeline = [
  {
    year: "2026 — now",
    role: "独立开发者 · Builder",
    what: "在造一路记 WayLog（旅行控制台 + Agent 提案式编辑），跟踪 AI 前沿写所学。",
    link: { label: "WayLog", href: "https://github.com/yugonglian2333/WayLog" },
  },
  {
    year: "[占位]",
    role: "[角色 / 公司]",
    what: "[一句话做了什么、解决了什么、留下什么]",
    link: null,
  },
  {
    year: "[占位]",
    role: "[更早的一段经历]",
    what: "[一句话]",
    link: null,
  },
];

// 技能栈分组（先借 WayLog 真实技术栈填一组，后续按真实情况调整）
const skills = [
  {
    group: "前端 / 客户端",
    items: ["React Native", "React 19", "Expo SDK 54", "Expo Router", "Next.js", "Astro", "Tailwind CSS"],
  },
  {
    group: "后端 / 云",
    items: ["Supabase", "Postgres + RLS", "Edge Functions (Deno)", "Realtime", "Vercel"],
  },
  {
    group: "Agent / AI",
    items: ["AgentProposal 闭环", "OpenAI-compatible API", "Tavily / Brave 搜索", "提示工程"],
  },
  {
    group: "工程化",
    items: ["pnpm workspace", "TypeScript", "Biome", "Sentry", "node:test"],
  },
];
---

<BaseLayout title="简历 — RenOS" description="RenOS 的轻量简历：经历时间线 + 技能栈。">
  <section class="section">
    <!-- 顶部一句话定位 -->
    <div data-fade>
      <h1 class="text-3xl font-bold tracking-tight">简历</h1>
      <p class="mt-3 text-[15px] leading-relaxed" style="color: var(--color-text-muted);">
        AI builder <span style="color: var(--color-accent);">&amp;</span> BTC holder.
        在造旅行助手一路记 WayLog，做 Agent 提案式编辑闭环。下面是经历和技能栈，
        项目细节见 <a href="/projects" class="link-quiet">项目</a>，
        想法碎片见 <a href="/blog" class="link-quiet">文章</a>。
      </p>

      <!-- 下载 PDF -->
      <a
        href="/resume.pdf"
        download
        class="mt-5 inline-flex items-center gap-2 rounded-[var(--radius-button)] px-5 py-2.5 text-sm font-medium transition-colors"
        style="background: var(--color-accent); color: var(--color-accent-contrast);"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
          <polyline points="7 10 12 15 17 10" />
          <line x1="12" y1="15" x2="12" y2="3" />
        </svg>
        下载 PDF 简历
      </a>
    </div>

    <!-- 经历时间线 -->
    <div class="mt-12" data-fade>
      <SectionTitle eyebrow="01" title="经历" />
      <div class="flex flex-col">
        {timeline.map((item) => (
          <div class="flex gap-4 border-b py-4 sm:gap-8" style="border-color: var(--color-border);">
            <div class="w-24 shrink-0 font-mono text-xs sm:text-sm" style="color: var(--color-text-subtle);">
              {item.year}
            </div>
            <div class="min-w-0 flex-1">
              <div class="text-[15px] font-medium">{item.role}</div>
              <p class="mt-1 text-sm leading-relaxed" style="color: var(--color-text-muted);">
                {item.what}
                {item.link && (
                  <>
                    {" "}
                    <a href={item.link.href} target="_blank" rel="noopener noreferrer" class="link-quiet">
                      {item.link.label} ↗
                    </a>
                  </>
                )}
              </p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- 技能栈 -->
    <div class="mt-12" data-fade>
      <SectionTitle eyebrow="02" title="技能栈" />
      <div class="flex flex-col gap-5">
        {skills.map((s) => (
          <div>
            <div class="mb-2 font-mono text-xs uppercase tracking-wider" style="color: var(--color-text-subtle);">
              {s.group}
            </div>
            <div class="flex flex-wrap gap-1.5">
              {s.items.map((item) => <span class="tag">{item}</span>)}
            </div>
          </div>
        ))}
      </div>
      <p class="mt-4 text-xs" style="color: var(--color-text-subtle);">
        实战证据见 <a href="/projects" class="link-quiet">一路记 WayLog</a>，技术栈以仓库实际使用为准。
      </p>
    </div>

    <!-- 联系 -->
    <div class="mt-12" data-fade>
      <SectionTitle eyebrow="03" title="联系" />
      <p class="text-sm" style="color: var(--color-text-muted);">
        GitHub <a href="https://github.com/yugonglian2333" target="_blank" rel="noopener noreferrer" class="link-quiet">@yugonglian2333</a>
        · 邮箱 <a href="mailto:1070881879@qq.com" class="link-quiet">1070881879@qq.com</a>
        · <a href="/resume.pdf" download class="link-quiet">下载 PDF 简历</a>
      </p>
    </div>
  </section>
</BaseLayout>