---
import BaseLayout from "../layouts/BaseLayout.astro";
import { Icon } from "astro-icon/components";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latest = posts.slice(0, 4);
---

<BaseLayout>
  <section class="section">
    <!-- ===== Hero ===== -->
    <div data-fade>
      <div class="flex items-center gap-4">
        <img src="/ren-avatar.jpg" alt="Ren" width="48" height="48" class="h-12 w-12 rounded-full border object-cover" style="border-color: var(--color-accent-soft);" />
        <div>
          <p class="font-mono text-xs uppercase tracking-[0.15em]" style="color: var(--color-accent);">RenOS</p>
          <p class="font-mono text-[11px]" style="color: var(--color-text);">雨宫莲</p>
        </div>
      </div>

      <h1 class="mt-10 font-serif text-[32px] font-medium leading-[1.15] tracking-tight sm:text-[42px]">
        Agent dev <span style="color: var(--color-accent);">&amp;</span> GISer
      </h1>

      <p class="mt-5 max-w-xl text-[15px] leading-relaxed sm:text-base" style="color: var(--color-text-muted);">
        你好，我是 RenOS，也叫雨宫莲，一个从地理信息走向 AI Agent 的 00 后 builder。现在主要在做旅行助手「<a href="/projects" class="link-quiet" style="color: var(--color-accent); border-bottom-color: color-mix(in oklab, var(--color-accent) 35%, transparent);">一路记 WayLog</a>」，一个用于一站式解决所有旅行行程规划的 Agent 智能应用，正努力将其打磨成一个丝滑的 APP。
      </p>
      <p class="mt-3 max-w-xl text-[15px] leading-relaxed sm:text-base" style="color: var(--color-text-muted);">
        我也会持续记录 AI 前沿、工程实践和自己的长期项目，vibe coding 一些小创意、小项目。把探索、试错、热爱和一点点个人趣味，都沉淀在这里。这片茫茫的信息海里，能被你读到，是我的荣幸。
      </p>

      <div class="mt-5 flex flex-wrap gap-1.5">
        <span class="tag">AI builder</span>
        <span class="tag">GISer</span>
        <span class="tag">INTJ</span>
        <span class="tag">00 后</span>
      </div>

      <!-- 社交行 -->
      <div class="mt-8 flex items-center gap-5" style="color: var(--color-text-subtle);">
        <a href="https://github.com/yugonglian2333" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-[color:var(--color-accent)]" aria-label="GitHub">
          <Icon name="mdi:github" class="h-5 w-5" />
        <a href="https://x.com/yugonglian12" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-[color:var(--color-accent)]" aria-label="X / Twitter">
          <Icon name="simple-icons:x" class="h-[17px] w-[17px]" />
        <a href="https://space.bilibili.com/10033138" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-[color:var(--color-accent)]" aria-label="Bilibili">
          <svg class="h-[18px] w-[18px]" viewBox="0 0 24 24" fill="currentColor"><path d="M17.813 4.653h.854c1.51.054 2.769.578 3.773 1.574 1.004.995 1.524 2.249 1.56 3.76v7.36c-.036 1.51-.556 2.769-1.56 3.773s-2.262 1.524-3.773 1.56H5.333c-1.51-.036-2.769-.556-3.773-1.56S.036 18.858 0 17.347v-7.36c.036-1.511.556-2.765 1.56-3.76 1.004-.996 2.262-1.52 3.773-1.574h.774l-1.174-1.12a1.234 1.234 0 0 1-.373-.906c0-.356.124-.658.373-.907l.027-.027c.267-.249.573-.373.92-.373.347 0 .653.124.92.373L9.653 4.44c.071.071.134.142.187.213h4.267a.836.836 0 0 1 .16-.213l2.853-2.747c.267-.249.573-.373.92-.373.347 0 .662.151.929.4.267.249.391.551.391.907 0 .355-.124.657-.373.906zM5.333 7.24c-.746.018-1.373.276-1.88.773-.506.498-.769 1.13-.786 1.894v7.52c.017.764.28 1.395.786 1.893.507.498 1.134.756 1.88.773h13.334c.746-.017 1.373-.275 1.88-.773.506-.498.769-1.129.786-1.893v-7.52c-.017-.765-.28-1.396-.786-1.894-.507-.497-1.134-.755-1.88-.773zM8 11.107c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c0-.373.129-.689.386-.947.258-.257.574-.386.947-.386zm8 0c.373 0 .684.124.933.373.25.249.383.569.4.96v1.173c-.017.391-.15.711-.4.96-.249.25-.56.374-.933.374s-.684-.125-.933-.374c-.25-.249-.383-.569-.4-.96V12.44c.017-.391.15-.711.4-.96.249-.249.56-.373.933-.373z"/></svg>
        </a>
        <a href="https://www.xiaohongshu.com/user/profile/62ec05a0000000001f016df6" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-[color:var(--color-accent)]" aria-label="小红书">
          <svg class="h-[16px] w-[16px]" viewBox="0 0 24 24" fill="currentColor"><path d="M22.405 9.879c.002.016.01.02.07.019h.725a.797.797 0 0 0 .78-.972.794.794 0 0 0-.884-.618.795.795 0 0 0-.692.794c0 .101-.002.666.001.777zm-11.509 4.808c-.203.001-1.353.004-1.685.003a2.528 2.528 0 0 1-.766-.126.025.025 0 0 0-.03.014L7.7 16.127a.025.025 0 0 0 .01.032c.111.06.336.124.495.124.66.01 1.32.002 1.981 0 .01 0 .02-.006.023-.015l.712-1.545a.025.025 0 0 0-.024-.036zM.477 9.91c-.071 0-.076.002-.076.01a.834.834 0 0 0-.01.08c-.027.397-.038.495-.234 3.06-.012.24-.034.389-.135.607-.026.057-.033.042.003.112.046.092.681 1.523.787 1.74.008.015.011.02.017.02.008 0 .033-.026.047-.044.147-.187.268-.391.371-.606.306-.635.44-1.325.486-1.706.014-.11.021-.22.03-.33l.204-2.616.022-.293c.003-.029 0-.033-.03-.034zm7.203 3.757a1.427 1.427 0 0 1-.135-.607c-.004-.084-.031-.39-.235-3.06a.443.443 0 0 0-.01-.082c-.004-.011-.052-.008-.076-.008h-1.48c-.03.001-.034.005-.03.034l.021.293c.076.982.153 1.964.233 2.946.05.4.186 1.085.487 1.706.103.215.223.419.37.606.015.018.037.051.048.049.02-.003.742-1.642.804-1.765.036-.07.03-.055.003-.112zm3.861-.913h-.872a.126.126 0 0 1-.116-.178l1.178-2.625a.025.025 0 0 0-.023-.035l-1.318-.003a.148.148 0 0 1-.135-.21l.876-1.954a.025.025 0 0 0-.023-.035h-1.56c-.01 0-.02.006-.024.015l-.926 2.068c-.085.169-.314.634-.399.938a.534.534 0 0 0-.02.191.46.46 0 0 0 .23.378.981.981 0 0 0 .46.119h.59c.041 0-.688 1.482-.834 1.972a.53.53 0 0 0-.023.172.465.465 0 0 0 .23.398c.15.092.342.12.475.12l1.66-.001c.01 0 .02-.006.023-.015l.575-1.28a.025.025 0 0 0-.024-.035zm-6.93-4.937H3.1a.032.032 0 0 0-.034.033c0 1.048-.01 2.795-.01 6.829 0 .288-.269.262-.28.262h-.74c-.04.001-.044.004-.04.047.001.037.465 1.064.555 1.263.01.02.03.033.051.033.157.003.767.009.938-.014.153-.02.3-.06.438-.132.3-.156.49-.419.595-.765.052-.172.075-.353.075-.533.002-2.33 0-4.66-.007-6.991a.032.032 0 0 0-.032-.032zm11.784 6.896c0-.014-.01-.021-.024-.022h-1.465c-.048-.001-.049-.002-.05-.049v-4.66c0-.072-.005-.07.07-.07h.863c.08 0 .075.004.075-.074V8.393c0-.082.006-.076-.08-.076h-3.5c-.064 0-.075-.006-.075.073v1.445c0 .083-.006.077.08.077h.854c.075 0 .07-.004.07.07v4.624c0 .095.008.084-.085.084-.37 0-1.11-.002-1.304 0-.048.001-.06.03-.06.03l-.697 1.519s-.014.025-.008.036c.006.01.013.008.058.008 1.748.003 3.495.002 5.243.002.03-.001.034-.006.035-.033v-1.539zm4.177-3.43c0 .013-.007.023-.02.024-.346.006-.692.004-1.037.004-.014-.002-.022-.01-.022-.024-.005-.434-.007-.869-.01-1.303 0-.072-.006-.071.07-.07l.733-.003c.041 0 .081.002.12.015.093.025.16.107.165.204.006.431.002 1.153.001 1.153zm2.67.244a1.953 1.953 0 0 0-.883-.222h-.18c-.04-.001-.04-.003-.042-.04V10.21c0-.132-.007-.263-.025-.394a1.823 1.823 0 0 0-.153-.53 1.533 1.533 0 0 0-.677-.71 2.167 2.167 0 0 0-1-.258c-.153-.003-.567 0-.72 0-.07 0-.068.004-.068-.065V7.76c0-.031-.01-.041-.046-.039H17.93s-.016 0-.023.007c-.006.006-.008.012-.008.023v.546c-.008.036-.057.015-.082.022h-.95c-.022.002-.028.008-.03.032v1.481c0 .09-.004.082.082.082h.913c.082 0 .072.128.072.128V11.19s.003.117-.06.117h-1.482c-.068 0-.06.082-.06.082v1.445s-.01.068.064.068h1.457c.082 0 .076-.006.076.079v3.225c0 .088-.007.081.082.081h1.43c.09 0 .082.007.082-.08v-3.27c0-.029.006-.035.033-.035l2.323-.003c.098 0 .191.02.28.061a.46.46 0 0 1 .274.407c.008.395.003.79.003 1.185 0 .259-.107.367-.33.367h-1.218c-.023.002-.029.008-.028.033.184.437.374.871.57 1.303a.045.045 0 0 0 .04.026c.17.005.34.002.51.003.15-.002.517.004.666-.01a2.03 2.03 0 0 0 .408-.075c.59-.18.975-.698.976-1.313v-1.981c0-.128-.01-.254-.034-.38 0 .078-.029-.641-.724-.998z"/></svg>
        </a>
        <span class="h-3 w-px" style="background: color-mix(in oklab, var(--color-accent) 36%, var(--color-border));"></span>
        <a href="/uses" class="font-mono text-[12px] transition-colors hover:text-[color:var(--color-accent-hover)]" style="color: var(--color-accent);">装备</a>
        <a href="/bookmarks" class="font-mono text-[12px] transition-colors hover:text-[color:var(--color-accent-hover)]" style="color: var(--color-accent);">收藏</a>
      </div>
    </div>

    <!-- ===== 分隔 ===== -->
    <hr class="my-16 border-0" style="height: 1px; background: color-mix(in oklab, var(--color-accent) 24%, var(--color-border));" data-fade />

    <!-- ===== 旗舰项目 ===== -->
    <a href="/projects" class="block transition-colors hover:opacity-80" data-fade>
      <div class="flex items-center justify-between">
        <p class="font-mono text-xs uppercase tracking-[0.12em]" style="color: var(--color-accent);">旗舰项目</p>
        <span class="font-mono text-[11px]" style="color: var(--color-accent);">全部 →</span>
      </div>
      <h2 class="mt-3 font-serif text-2xl font-medium leading-tight tracking-tight transition-colors hover:text-[color:var(--color-accent)]">
        一路记 WayLog
      </h2>
      <p class="mt-2 text-sm" style="color: var(--color-text-muted);">
        旅行控制台 + Agent 提案式编辑。让 AI 只能提议，不能擅动。
      </p>
      <div class="mt-4 flex flex-wrap gap-1.5">
        <span class="tag">RN</span>
        <span class="tag">Expo</span>
        <span class="tag">Supabase</span>
      </div>
    </a>

    <!-- ===== 分隔 ===== -->
    <hr class="my-16 border-0" style="height: 1px; background: color-mix(in oklab, var(--color-accent) 24%, var(--color-border));" data-fade />

    <!-- ===== 最新文章 ===== -->
    <div data-fade>
      <div class="flex items-center justify-between">
        <p class="font-mono text-xs uppercase tracking-[0.12em]" style="color: var(--color-accent);">最新文章</p>
        <a href="/blog" class="font-mono text-[11px] transition-colors hover:text-[color:var(--color-accent-hover)]" style="color: var(--color-accent);">全部 →</a>
      </div>
      <h2 class="mt-3 font-serif text-2xl font-medium leading-tight tracking-tight">
        <a href={"/blog/" + (latest[0]?.slug ?? "")} class="transition-colors hover:text-[color:var(--color-accent)]">{latest[0]?.data.title ?? "AI 周记 #1"}</a>
      </h2>
      <p class="mt-2 text-sm" style="color: var(--color-text-muted);">
        {latest[0]?.data.description ?? "占位待填"}
      </p>
      {latest[0] && (
        <p class="mt-3 font-mono text-[11px]" style="color: var(--color-text-subtle);">
          {new Date(latest[0].data.pubDate).toLocaleDateString("zh-CN", { year: "numeric", month: "long", day: "numeric" })}
          {latest[0].data.category && <span> · {latest[0].data.category}</span>}
        </p>
      )}
    </div>

    <!-- ===== 分隔 ===== -->
    <hr class="my-16 border-0" style="height: 1px; background: color-mix(in oklab, var(--color-accent) 24%, var(--color-border));" data-fade />

    <!-- ===== 此刻 · 关于 ===== -->
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2" data-fade>
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.12em]" style="color: var(--color-accent);">此刻</p>
        <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-text-muted);">
          正在做 Agent 开发，关注 AI 前沿动态。
        </p>
        <a href="/now" class="mt-3 inline-flex items-center gap-1 font-mono text-[11px] transition-colors hover:text-[color:var(--color-accent-hover)]" style="color: var(--color-accent);">
          了解更多 →
        </a>
      </div>
      <div>
        <p class="font-mono text-xs uppercase tracking-[0.12em]" style="color: var(--color-accent);">关于</p>
        <p class="mt-3 text-sm leading-relaxed" style="color: var(--color-text-muted);">
          如果你更想了解我一点
        </p>
        <a href="/about" class="mt-3 inline-flex items-center gap-1 font-mono text-[11px] transition-colors hover:text-[color:var(--color-accent-hover)]" style="color: var(--color-accent);">
          认识我 →
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
