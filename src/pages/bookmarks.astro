---
import BaseLayout from "../layouts/BaseLayout.astro";
import d from "../data/bookmarks.json";

const categories = d.categories;
---

<BaseLayout title="收藏 — RenOS" description="RenOS 收藏的好内容：AI、设计、技术。">
  <section class="section">
    <div data-fade>
      <p class="font-mono text-xs uppercase tracking-[0.15em]" style="color: var(--color-accent);">收藏</p>
      <h1 class="mt-3 font-serif text-3xl font-medium tracking-tight sm:text-4xl">/bookmarks</h1>
      <div class="mt-6 border-l-4 pl-5" data-fade style="border-color: var(--color-accent);">
        <p class="font-serif text-base leading-relaxed sm:text-lg">
          跟踪 AI 前沿、攒设计灵感、学技术——这些是我反复回看的好东西。
        </p>
        <p class="mt-1 text-sm" style="color: var(--color-text-muted);">不求全，只放真心有用的。</p>
      </div>
    </div>

    {categories.map((cat, idx) => (
      <div class="mt-10" data-fade>
          <p class="font-mono text-xs uppercase tracking-[0.15em]" style="color: var(--color-accent);">{cat.label}</p>
        <div class="flex flex-col">
          {cat.items.map((item) => (
            <a
              href={item.url}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex items-baseline justify-between gap-4 border-b py-3 transition-colors"
              style="border-color: var(--color-border);"
            >
              <div class="min-w-0 flex-1">
                <span class="text-[14px] font-medium group-hover:text-[color:var(--color-accent)] transition-colors">{item.name}</span>
                <span class="ml-3 text-xs" style="color: var(--color-text-subtle);">{item.note}</span>
              </div>
              <svg class="icon h-3 w-3 shrink-0 group-hover:translate-x-0.5 group-hover:-translate-y-0.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-text-subtle);"><path d="M7 17L17 7"/><path d="M7 7h10v10"/></svg>
            </a>
          ))}
        </div>
      </div>
    ))}

    <p class="mt-12 text-xs" style="color: var(--color-text-subtle);" data-fade>
      持续更新中。有好东西欢迎 <a href="mailto:1070881879@qq.com" class="link-quiet">推荐给我</a>。
    </p>
  </section>
</BaseLayout>
