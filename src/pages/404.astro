---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="404 — 找不到页面" description="页面走丢了。">
  <section class="section flex min-h-[50vh] flex-col items-center justify-center text-center">
    <div data-fade>
      <div class="font-mono text-6xl font-bold" style="color: var(--color-accent);">404</div>
      <h1 class="mt-4 text-2xl font-semibold">这条路没有方向</h1>
      <p class="mt-2 text-sm" style="color: var(--color-text-muted);">
        也许从未存在，也许被搬走了。
      </p>
      <a href="/" class="mt-8 inline-flex items-center gap-1.5 rounded-[var(--radius-button)] px-4 py-2 text-sm font-medium transition-colors" style="background: var(--color-accent); color: var(--color-accent-contrast);">
        回首页 →
      </a>
    </div>
  </section>
</BaseLayout>