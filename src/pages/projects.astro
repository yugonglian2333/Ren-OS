---
import BaseLayout from "../layouts/BaseLayout.astro";
import d from "../data/projects.json";

const waylogTags = d.waylogTags;
const waylogPoints = d.waylogPoints;
const waylogLinks = d.waylogLinks;
const saymoreTags = d.saymoreTags;
const saymorePoints = d.saymorePoints;
const saymoreLinks = d.saymoreLinks;
---

<BaseLayout title="项目 — RenOS" description="一路记 WayLog 与 Saymore：我正在打造的旅行助手和桌面语音输入工具。">
  <section class="section">
    <p class="font-mono text-xs uppercase tracking-[0.15em]" style="color: var(--color-accent);" data-fade>项目</p>
    <h1 class="mt-3 font-serif text-3xl font-medium tracking-tight" data-fade>一路记 WayLog</h1>

    <div class="mt-2 flex items-center gap-3" data-fade>
      <span class="rounded-[var(--radius-sm)] px-2.5 py-0.5 text-xs font-medium" style="background: var(--color-accent-soft); color: var(--color-accent);">旗舰项目</span>
      <span class="font-mono text-xs" style="color: var(--color-text-subtle);">2026 · 进行中</span>
    </div>

    <div class="mt-8 border-l-4 pl-5" style="border-color: var(--color-accent);" data-fade>
      <p class="font-serif text-lg font-medium leading-relaxed sm:text-xl">
        个人旅行助手 App。把旅行计划、每日行程、地点收藏、预算记录、重要备忘和
        Agent 辅助编辑收拢成一个旅行控制台 + 旅行手记。
      </p>
    </div>

    <div class="mt-10" data-fade>
      <p class="font-mono text-xs uppercase tracking-[0.12em]" style="color: var(--color-text-subtle);">能力</p>
      <ul class="mt-4 flex flex-col gap-4">
        {waylogPoints.map((p) => (
          <li class="flex items-start gap-3 text-[14px] leading-relaxed" style="color: var(--color-text-muted);">
            <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--color-accent);"></span>
            <span>{p}</span>
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-10" data-fade>
      <p class="font-mono text-xs uppercase tracking-[0.12em]" style="color: var(--color-text-subtle);">技术栈</p>
      <div class="mt-3 flex flex-wrap gap-1.5">
        {waylogTags.map((t) => <span class="tag">{t}</span>)}
      </div>
    </div>

    <div class="mt-8 flex flex-wrap gap-3" data-fade>
      {waylogLinks.map((l) => (
        <a
          href={l.href}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1.5 rounded-[var(--radius-button)] border px-4 py-2 text-sm font-medium transition-colors hover:text-[color:var(--color-accent)]"
          style="border-color: var(--color-border);"
        >
          {l.label} ↗
        </a>
      ))}
    </div>

    <hr class="my-14 border-0" style="height: 1px; background: var(--color-border);" data-fade />

    <div data-fade>
      <h2 class="font-serif text-3xl font-medium tracking-tight">Saymore</h2>

      <div class="mt-2 flex items-center gap-3">
        <span class="rounded-[var(--radius-sm)] px-2.5 py-0.5 text-xs font-medium" style="background: var(--color-accent-soft); color: var(--color-accent);">开源产品</span>
        <span class="font-mono text-xs" style="color: var(--color-text-subtle);">2026 · 已落地</span>
      </div>

      <div class="mt-8 border-l-4 pl-5" style="border-color: var(--color-accent);">
        <p class="font-serif text-lg font-medium leading-relaxed sm:text-xl">
          想到什么，就直接说。Saymore 会把停顿、口误和自我修正整理成可以直接使用的文字。
        </p>
      </div>

      <p class="mt-6 text-[15px] leading-7" style="color: var(--color-text-muted);">
        Saymore 是一款本地优先的桌面语音输入工具。无论正在使用微信、飞书、浏览器、邮件还是编辑器，
        只需按下全局快捷键自然说话，它就会完成语音识别，自动清理口语冗余、补充标点、整理结构，
        并将最终文字直接写入当前输入框。
      </p>
      <p class="mt-3 text-[15px] leading-7" style="color: var(--color-text-muted);">
        Saymore 支持中英混合表达、个人词典以及可选的 LLM 文本精炼。ASR 与 LLM 均不绑定单一服务商，
        你可以选择本地模型或自己的 Provider，在提升输入效率的同时，保留对模型、隐私和数据流向的控制权。
      </p>

      <div class="mt-10">
        <p class="font-mono text-xs uppercase tracking-[0.12em]" style="color: var(--color-text-subtle);">能力</p>
        <ul class="mt-4 flex flex-col gap-4">
          {saymorePoints.map((p) => (
            <li class="flex items-start gap-3 text-[14px] leading-relaxed" style="color: var(--color-text-muted);">
              <span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full" style="background: var(--color-accent);"></span>
              <span>{p}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="mt-10">
        <p class="font-mono text-xs uppercase tracking-[0.12em]" style="color: var(--color-text-subtle);">技术与特性</p>
        <div class="mt-3 flex flex-wrap gap-1.5">
          {saymoreTags.map((t) => <span class="tag">{t}</span>)}
        </div>
      </div>

      <div class="mt-8 flex flex-wrap gap-3">
        {saymoreLinks.map((link) => link.href ? (
          <a
            href={link.href}
            target={link.href.startsWith("http") ? "_blank" : undefined}
            rel={link.href.startsWith("http") ? "noopener noreferrer" : undefined}
            class="inline-flex items-center gap-1.5 rounded-[var(--radius-button)] border px-4 py-2 text-sm font-medium transition-colors hover:text-[color:var(--color-accent)]"
            style="border-color: var(--color-border);"
          >
            {link.label} {link.href.startsWith("http") ? "↗" : "→"}
          </a>
        ) : (
          <span
            class="inline-flex cursor-not-allowed items-center gap-1.5 rounded-[var(--radius-button)] border px-4 py-2 text-sm font-medium"
            style="border-color: var(--color-border); color: var(--color-text-subtle);"
            aria-label={`${link.label}，${link.status}`}
          >
            {link.label} · {link.status}
          </span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
